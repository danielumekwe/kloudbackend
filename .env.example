APP_NAME=Kloud101
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# -------------------------------------------------------------------------
# WHMCS API — https://developers.whmcs.com/api/getting-started/
# -------------------------------------------------------------------------
WHMCS_URL=https://billing.yourdomain.com
WHMCS_API_IDENTIFIER=your_api_identifier_here
WHMCS_API_SECRET=your_api_secret_here

# -------------------------------------------------------------------------
# WHMCS database — read-only access, used only by the one-time `whmcs:migrate-*`
# commands during the phased WHMCS exit. Leave blank unless actively migrating.
# -------------------------------------------------------------------------
WHMCS_DB_HOST=127.0.0.1
WHMCS_DB_PORT=3306
WHMCS_DB_DATABASE=
WHMCS_DB_USERNAME=
WHMCS_DB_PASSWORD=

# -------------------------------------------------------------------------
# InterServer VPS API
# -------------------------------------------------------------------------
INTERSERVER_API_KEY=your_interserver_api_key_here

# -------------------------------------------------------------------------
# Notifications
# -------------------------------------------------------------------------
# Mailbox that receives admin-facing notifications (new tickets, etc.)
ADMIN_NOTIFICATION_EMAIL=support@kloud101.com

# -------------------------------------------------------------------------
# Social login — Google (https://console.cloud.google.com/apis/credentials)
# Facebook (https://developers.facebook.com/apps)
# Redirect URIs must be registered in each provider's console, e.g.
# https://yourdomain.com/auth/google/callback and /auth/facebook/callback
# -------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"

FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_REDIRECT_URI="${APP_URL}/auth/facebook/callback"

# -------------------------------------------------------------------------
# Account codes
# -------------------------------------------------------------------------
# Salt for the customer-facing account code (App\Models\Client::accountCode).
# Generate with: php -r "echo random_int(1, 16777215);"
# Set once and keep secret — changing it invalidates every account code already
# shown to a customer.
ACCOUNT_CODE_SALT=

# Same idea, for support ticket reference numbers (App\Models\SupportTicket::ticketCode).
# Generate with: php -r "echo random_int(1, 16777215);"
TICKET_CODE_SALT=
